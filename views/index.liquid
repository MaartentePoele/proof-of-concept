{% include 'partials/head.liquid' %}
    <main class="home-main">
      <section class="dashboard">
        <h1>Dashboard Nederland</h1>

        <dl class="dashboard-boxes">
          <div class="dashboard-box">
            <dt class="dashboard-box-heading">Smart zone geschiktheid</dt>
            <dd class="dashboard-box-value">{{ smartzoneGeschiktPercentage | round }}%</dd>
          </div>
          <div class="dashboard-box">
            <dt class="dashboard-box-heading">In overtreding</dt>
            <dd class="dashboard-box-value">{{ overtredingPercentage | round }}%</dd>
          </div>
          <div class="dashboard-box">
            <dt class="dashboard-box-heading">Quickscans</dt>
            <dd class="dashboard-box-value">{{ quickscanAmount.count }}</dd>
          </div>
          <div class="dashboard-box">
            <dt class="dashboard-box-heading">Steden</dt>
            <dd class="dashboard-box-value">{{ cityAmount }}</dd>
          </div>
        </dl>
      </section>

      <nav class="city-nav">
        <h3 class="city-heading">Steden</h3>
    {%- for city in cities %}
      {%- if city.city != null %}
        <a href="/{{ city.city }}">{{ city.city }}</a>
      {%- endif %}
    {%- endfor %}
      </nav>
    </main>

{% include 'partials/quickscan.liquid' %}
{% include 'partials/foot.liquid' %}
