{% include 'partials/head.liquid' %}
<main>
  <section class="dashboard">
    <h1>Dashboard Nederland</h1>

    <div class="dashboard-boxes">
      <div class="dashboard-box">
        <h2 class="dashboard-box-heading">Smart zone geschikt</h2>
        <span class="dashboard-box-value">{{ smartzoneGeschiktPercentage | round }}%</span>
      </div>
      <div class="dashboard-box">
        <h2 class="dashboard-box-heading">Steden</h2>
        <span class="dashboard-box-value">{{ cityAmount }}</span>
      </div>
      <div class="dashboard-box">
        <h2 class="dashboard-box-heading">Vrij</h2>
        <span class="dashboard-box-value">{{ vrijPercentage | round }}%</span>
      </div>
      <div class="dashboard-box">
        <h2 class="dashboard-box-heading">Quickscans</h2>
        <span class="dashboard-box-value">{{ quickscanAmount.count }}</span>
      </div>
    </div>
  </section>

  <nav class="city-nav">
    <h3 class="city-heading">Steden</h3>
    {% for city in cities %}
      {% if city.city != null %}
        <a href="/{{ city.city }}">{{ city.city }}</a>
      {% endif %}
    {% endfor %}
  </nav>
</main>

{% include 'partials/quickscan.liquid' %}
{% include 'partials/foot.liquid' %}
