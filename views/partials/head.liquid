<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Coding the Curbs - Dashboard</title>
    <link rel="stylesheet" href="/assets/styles/stylesheet.css">
    <link rel="stylesheet" href="/assets/styles/style.css">
    <script src="/assets/scripts/script.js" defer></script>
  </head>

  <body>
    <header>
      <a href="/" class="logo">
        <img src="/assets/images/purple-logo.svg" alt="Coding the Curbs home" width="150" height="46">
      </a>

      <button class="menu" aria-label="menu">
        <div class="line1"></div>
        <div class="line2"></div>
        <div class="line3"></div>
      </button>

      <nav class="menu-nav">
    {%- for city in cities %}
      {%- if city.city != null %}
        <a href="/{{ city.city }}">{{ city.city }}</a>
      {%- endif %}
    {%- endfor %}
      </nav>
    </header>
